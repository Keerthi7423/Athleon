# --- Athleon Platform Environment Variables ---

# Global Settings
NODE_ENV=production
JWT_SECRET=athleon_super_secret_key_2026
JWT_EXPIRES_IN=1d

# Database Settings (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=athleon
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://postgres:password@db:5432/athleon

# Caching Settings (Redis)
REDIS_URL=redis://redis:6379

# Service Discovery / URLs
API_GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://auth-service:4001
FATIGUE_SERVICE_URL=http://fatigue-service:4002
EMI_SERVICE_URL=http://emi-service:4003
ANALYTICS_SERVICE_URL=http://analytics-api:4000

# Auth Service Specifics
BCRYPT_SALT_ROUNDS=12
ALLOWED_ORIGIN=*
